if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Environment
export ZSH_PLUGIN_DIR="$HOME/.config/zsh/plugins"
export NVIM_APPNAME="lazyvim"
export EDITOR="nvim"
export VISUAL="nvim"
path=("$HOME/bin" "$HOME/.local/bin" $path)
typeset -U path PATH

# Home Manager session vars (PATH etc.)
if [ -f "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh" ]; then
  . "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"
fi

# Aliases
[[ -r "$HOME/.config/shell/aliases.sh" ]] && source "$HOME/.config/shell/aliases.sh"

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=5000                    # Maximum events for internal history
SAVEHIST=5000                    # Maximum events in history file
setopt appendhistory             # Append rather than overwrite
setopt share_history             # Share history between all sessions.
setopt hist_ignore_space         # Do not record an event starting with a space.
setopt hist_expire_dups_first    # Expire a duplicate event first when trimming history.
setopt hist_ignore_dups          # Do not record an event that was just recorded again.
setopt hist_ignore_all_dups      # Delete an old recorded event if a new event is a duplicate.
setopt hist_find_no_dups         # Do not display a previously found event.
setopt hist_save_no_dups         # Do not write a duplicate event to the history file.
setopt hist_verify               # Do not execute immediately upon history expansion.

# Configure completions including fzf
_comp_options+=(globdots)       # Complete hidden(dot)files
zstyle ':completion:*' menu no                              # Disable zsh complete menus (because plugin handles them)
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'   # Case insensitive completion
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"     # Color the completions
zstyle ':fzf-tab:*' fzf-bindings 'tab:accept' # Use tab as enter instead of going down the list
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath' # Use fzf tab for cd completions

# Enable completions
autoload -Uz compinit && compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"

# Plugins
plugins=(
  "fzf-tab/fzf-tab.plugin.zsh"
  "zsh-vi-mode/zsh-vi-mode.plugin.zsh"
  "zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  "zsh-autosuggestions/zsh-autosuggestions.zsh"
  "powerlevel10k/powerlevel10k.zsh-theme"
)

for plugin in "${plugins[@]}"; do
  plugin_file="$ZSH_PLUGIN_DIR/$plugin"
  [[ -r "$plugin_file" ]] && source "$plugin_file"
done

function zvm_after_init() {
  bindkey -M viins '^R' fzf-history-widget
  bindkey -M vicmd '^R' fzf-history-widget
  bindkey -M viins '^Y' autosuggest-accept
  bindkey -M vicmd '^Y' autosuggest-accept
}

# fzf + zoxide integration
export FZF_DEFAULT_OPTS='--height=45% --layout=reverse --border --cycle --preview-window=right,55%'
export FZF_CTRL_R_OPTS='--sort --exact'
export FZF_ALT_C_OPTS='--preview "eza -la --color=always {} 2>/dev/null || ls -la {}"'

if command -v fd >/dev/null; then
  export FZF_DEFAULT_COMMAND='fd --type f --follow --exclude .git'
fi

function zi() {
  command -v zoxide >/dev/null 2>&1 && command -v fzf >/dev/null 2>&1 || {
    builtin cd -- "${1:-$HOME}" || return
    return
  }

  local dir
  dir="$(zoxide query -l | fzf --prompt='zoxide> ' --tac --no-sort --exact)" || return
  builtin cd -- "$dir" || return
}

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

command -v fzf >/dev/null && eval "$(fzf --zsh)"
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

[[ -r ~/.p10k.zsh ]] && source ~/.p10k.zsh
