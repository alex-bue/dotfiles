# Backgrounds
set -g @bg0    "#232A2E"  # very dark grey
set -g @bg1    "#2D353B"  # dark blue-grey
set -g @bg2    "#343F44"  # medium dark blue-grey
set -g @bg3    "#3D484D"  # lighter blue-grey
set -g @bg4    "#475258"  # grey-green
set -g @border "#4F585E"  # mid grey

# Text
set -g @fg     "#D3C6AA"  # warm off-white
set -g @muted  "#859289"  # muted grey-green
set -g @faint  "#9DA9A0"  # light grey-green

# Accents
set -g @accent  "#A7C080" # green
set -g @accent2 "#7FBBB3" # teal
set -g @ok      "#83C092" # aqua-green
set -g @warn    "#DBBC7F" # yellow
set -g @err     "#E67E80" # red
set -g @special "#D699B6" # lavender

# Selection
set -g @sel_bg  "#543A48" # dark red
# (optional) if you ever want a dedicated selection fg:
# set -g @sel_fg "#{@bg1}"


